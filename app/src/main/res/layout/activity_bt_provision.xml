<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Başlık -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ESP32 Bluetooth Yapılandır"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ESP32'ye Bluetooth ile bağlanıp WiFi ve MQTT ayarlarını gönderin."
            android:textSize="13sp"
            android:textColor="#666"
            android:layout_marginBottom="16dp" />

        <!-- Bağlantı Durumu Kartı -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/view_bt_indicator"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="@drawable/circle_indicator"
                    android:backgroundTint="#9E9E9E"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/txt_bt_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bağlı değil"
                    android:textSize="14sp"
                    android:textColor="#333" />

                <Button
                    android:id="@+id/btn_bt_connect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bağlan"
                    android:textSize="13sp"
                    android:backgroundTint="#2E7D32" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- WiFi Bilgileri Kartı -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WiFi Bilgileri"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/edt_wifi_ssid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="WiFi Ağ Adı (SSID)"
                    android:inputType="text"
                    android:padding="12dp"
                    android:background="@drawable/rounded_background"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/edt_wifi_pass"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="WiFi Şifresi"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:background="@drawable/rounded_background" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- MQTT Bilgileri Kartı -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MQTT Broker"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/edt_mqtt_ip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Broker IP (ör: 192.168.1.100)"
                    android:inputType="text"
                    android:padding="12dp"
                    android:background="@drawable/rounded_background" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Uygulama ayarlarındaki MQTT IP ile aynı olmalı"
                    android:textSize="11sp"
                    android:textColor="#888"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Gönder Butonu -->
        <Button
            android:id="@+id/btn_send_config"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ESP32'ye Gönder"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#2E7D32"
            android:layout_marginBottom="12dp"
            android:enabled="false" />

        <!-- Log Alanı -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ESP32 Yanıtları"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/txt_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:text="—"
                    android:textSize="12sp"
                    android:textColor="#444"
                    android:fontFamily="monospace"
                    android:background="#F5F5F5"
                    android:padding="8dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
