<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_large">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_control"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="@dimen/padding_large" />

        <!-- Sensör Verisi Bölümü -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/padding_large">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="@dimen/padding_medium"
                android:background="@drawable/rounded_background"
                android:layout_marginEnd="@dimen/padding_small">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_ph"
                    android:textSize="@dimen/text_size_small"
                    android:textColor="@color/primary" />

                <TextView
                    android:id="@+id/txt_ph_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="pH: 7.0"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    android:textColor="@color/black" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="@dimen/padding_medium"
                android:background="@drawable/rounded_background"
                android:layout_marginEnd="@dimen/padding_small">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_ec"
                    android:textSize="@dimen/text_size_small"
                    android:textColor="@color/primary" />

                <TextView
                    android:id="@+id/txt_ec_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EC: 0.0"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    android:textColor="@color/black" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="@dimen/padding_medium"
                android:background="@drawable/rounded_background">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_temp"
                    android:textSize="@dimen/text_size_small"
                    android:textColor="@color/primary" />

                <TextView
                    android:id="@+id/txt_temp_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25.0°C"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    android:textColor="@color/black" />
            </LinearLayout>
        </LinearLayout>

        <!-- Depo Seviyesi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium"
            android:background="@drawable/rounded_background"
            android:layout_marginBottom="@dimen/padding_large">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_tank_level"
                android:textSize="@dimen/text_size_medium"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/padding_small" />

            <ProgressBar
                android:id="@+id/progress_tank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="?android:attr/progressBarStyleHorizontal" />

            <TextView
                android:id="@+id/txt_tank_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textSize="@dimen/text_size_medium"
                android:textColor="@color/success"
                android:layout_marginTop="@dimen/padding_small" />
        </LinearLayout>

        <!-- Pompa Kontrolleri -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pompa Kontrolleri"
            android:textSize="@dimen/text_size_large"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="@dimen/padding_medium" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/padding_medium">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_ph_down"
                android:textSize="@dimen/text_size_medium"
                android:gravity="center_vertical" />

            <Switch
                android:id="@+id/switch_ph_down"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/padding_medium">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_fertilizer_a"
                android:textSize="@dimen/text_size_medium"
                android:gravity="center_vertical" />

            <Switch
                android:id="@+id/switch_fertilizer_a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/padding_medium">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_fertilizer_b"
                android:textSize="@dimen/text_size_medium"
                android:gravity="center_vertical" />

            <Switch
                android:id="@+id/switch_fertilizer_b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/padding_large">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_circulation"
                android:textSize="@dimen/text_size_medium"
                android:gravity="center_vertical" />

            <Switch
                android:id="@+id/switch_circulation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_reset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_reset"
            android:textSize="@dimen/text_size_medium"
            android:backgroundTint="@color/error" />

    </LinearLayout>
</ScrollView>
