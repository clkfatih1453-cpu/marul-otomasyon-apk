<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- KART 1: Depo Su Seviyesi -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Depo Su Seviyesi" android:textSize="15sp" android:textStyle="bold" android:textColor="#1B5E20" />
                    <TextView android:id="@+id/txt_tank_level" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="100%" android:textSize="22sp" android:textStyle="bold" android:textColor="#2E7D32" />
                </LinearLayout>

                <ProgressBar android:id="@+id/progress_tank" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="22dp"
                    android:max="100" android:progress="100"
                    android:progressTint="#4CAF50" android:progressBackgroundTint="#C8E6C9"
                    android:layout_marginBottom="4dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0%" android:textSize="10sp" android:textColor="#888" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="25%" android:textSize="10sp" android:textColor="#888" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="50%" android:textSize="10sp" android:textColor="#888" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="75%" android:textSize="10sp" android:textColor="#888" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="100%" android:textSize="10sp" android:textColor="#888" android:gravity="end" />
                </LinearLayout>

                <TextView android:id="@+id/txt_water_added" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Eklenen su: -- L" android:textSize="12sp" android:textColor="#666" android:layout_marginTop="6dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KART 2: Ortam Sensörleri -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" app:cardCornerRadius="12dp" app:cardElevation="3dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Ortam Sensörleri" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="#1B5E20" android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="center" android:background="#F1F8E9"
                        android:padding="10dp" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Sicaklik" android:textSize="11sp" android:textColor="#666" android:gravity="center" />
                        <TextView android:id="@+id/txt_temp_value" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="--C" android:textSize="22sp" android:textStyle="bold" android:textColor="#333" android:gravity="center" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Ortam (0-70C)" android:textSize="10sp" android:textColor="#AAA" android:gravity="center" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="center" android:background="#F1F8E9"
                        android:padding="10dp" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Nem" android:textSize="11sp" android:textColor="#666" android:gravity="center" />
                        <TextView android:id="@+id/txt_humidity" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="--%"  android:textSize="22sp" android:textStyle="bold" android:textColor="#333" android:gravity="center" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Bagil nem" android:textSize="10sp" android:textColor="#AAA" android:gravity="center" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="center" android:background="#F1F8E9" android:padding="10dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Su Sicakligi" android:textSize="11sp" android:textColor="#666" android:gravity="center" />
                        <TextView android:id="@+id/txt_water_temp" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="--C" android:textSize="22sp" android:textStyle="bold" android:textColor="#333" android:gravity="center" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Besin cozeltisi" android:textSize="10sp" android:textColor="#AAA" android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KART 3: Besin Cozeltisi pH + EC -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" app:cardCornerRadius="12dp" app:cardElevation="3dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Besin Cozeltisi" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="#1B5E20" android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="center" android:background="#E8F5E9"
                        android:padding="14dp" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="pH" android:textSize="13sp" android:textColor="#666" android:gravity="center" />
                        <TextView android:id="@+id/txt_ph_value" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="--" android:textSize="36sp" android:textStyle="bold" android:textColor="#2E7D32" android:gravity="center" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Hedef: 5.5-6.2" android:textSize="11sp" android:textColor="#888" android:gravity="center" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="center" android:background="#E8F5E9" android:padding="14dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="EC (mS/cm)" android:textSize="13sp" android:textColor="#666" android:gravity="center" />
                        <TextView android:id="@+id/txt_ec_value" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="--" android:textSize="36sp" android:textStyle="bold" android:textColor="#2E7D32" android:gravity="center" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Iletkenlik degeri" android:textSize="11sp" android:textColor="#888" android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KART 4: Dozaj Gecmisi -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" app:cardCornerRadius="12dp" app:cardElevation="3dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Dozaj Gecmisi" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="#1B5E20" android:layout_marginBottom="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ESP32 tarafindan bildirilen toplam miktarlar"
                    android:textSize="11sp" android:textColor="#999" android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:background="#F9FBF9" android:padding="10dp" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Gubre A" android:textSize="12sp" android:textColor="#555" />
                        <TextView android:id="@+id/txt_fert_a_ml" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="-- ml" android:textSize="18sp" android:textStyle="bold" android:textColor="#2E7D32" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:background="#F9FBF9" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Gubre B" android:textSize="12sp" android:textColor="#555" />
                        <TextView android:id="@+id/txt_fert_b_ml" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="-- ml" android:textSize="18sp" android:textStyle="bold" android:textColor="#2E7D32" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:background="#F9FBF9" android:padding="10dp" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Asit (pH Dusur)" android:textSize="12sp" android:textColor="#555" />
                        <TextView android:id="@+id/txt_acid_ml" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="-- ml" android:textSize="18sp" android:textStyle="bold" android:textColor="#E65100" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:background="#F9FBF9" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Eklenen Su" android:textSize="12sp" android:textColor="#555" />
                        <TextView android:id="@+id/txt_water_added_total" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="-- L" android:textSize="18sp" android:textStyle="bold" android:textColor="#1565C0" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KART 5: Manuel Dozaj -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" app:cardCornerRadius="12dp" app:cardElevation="3dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Manuel Dozaj" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="#1B5E20" android:layout_marginBottom="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Butona basinca ml miktarini giriniz"
                    android:textSize="11sp" android:textColor="#999" android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="center" android:layout_marginEnd="6dp">
                        <Button android:id="@+id/btn_dose_fert_a" android:layout_width="match_parent" android:layout_height="52dp"
                            android:text="Gubre A" android:textSize="13sp" android:backgroundTint="#388E3C" />
                        <TextView android:id="@+id/txt_dose_fert_a" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Son: -- ml" android:textSize="11sp" android:textColor="#555"
                            android:gravity="center" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="center" android:layout_marginEnd="6dp">
                        <Button android:id="@+id/btn_dose_fert_b" android:layout_width="match_parent" android:layout_height="52dp"
                            android:text="Gubre B" android:textSize="13sp" android:backgroundTint="#388E3C" />
                        <TextView android:id="@+id/txt_dose_fert_b" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Son: -- ml" android:textSize="11sp" android:textColor="#555"
                            android:gravity="center" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="center">
                        <Button android:id="@+id/btn_dose_acid" android:layout_width="match_parent" android:layout_height="52dp"
                            android:text="Asit" android:textSize="13sp" android:backgroundTint="#E65100" />
                        <TextView android:id="@+id/txt_dose_acid" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Son: -- ml" android:textSize="11sp" android:textColor="#555"
                            android:gravity="center" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KART 6: Pompa Kontrolleri -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" app:cardCornerRadius="12dp" app:cardElevation="3dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pompa Kontrolleri" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="#1B5E20" android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="pH Dusurucusu" android:textSize="14sp" android:textColor="#333" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Asit dozaj pompasi" android:textSize="11sp" android:textColor="#999" />
                    </LinearLayout>
                    <Switch android:id="@+id/switch_ph_down" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE" android:layout_marginBottom="8dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gubre A Pompasi" android:textSize="14sp" android:textColor="#333" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Makro besin A" android:textSize="11sp" android:textColor="#999" />
                    </LinearLayout>
                    <Switch android:id="@+id/switch_fertilizer_a" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE" android:layout_marginBottom="8dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gubre B Pompasi" android:textSize="14sp" android:textColor="#333" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Makro besin B" android:textSize="11sp" android:textColor="#999" />
                    </LinearLayout>
                    <Switch android:id="@+id/switch_fertilizer_b" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE" android:layout_marginBottom="8dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sirkulasyon Pompasi" android:textSize="14sp" android:textColor="#333" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Besin cozeltisi dongusu" android:textSize="11sp" android:textColor="#999" />
                    </LinearLayout>
                    <Switch android:id="@+id/switch_circulation" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KART 7: Zamanlama -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" app:cardCornerRadius="12dp" app:cardElevation="3dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Zamanlama" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="#1B5E20" android:layout_marginBottom="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Baslangic ve bitis saatlerini ayarlayin"
                    android:textSize="11sp" android:textColor="#999" android:layout_marginBottom="14dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Su Devirdaim Pompasi" android:textSize="13sp" android:textColor="#333" />
                        <TextView android:id="@+id/txt_pump_timer" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="00:00 - 24:00 (tum gun)" android:textSize="12sp" android:textColor="#2E7D32" android:textStyle="bold" />
                    </LinearLayout>
                    <Button android:id="@+id/btn_pump_timer" android:layout_width="wrap_content" android:layout_height="40dp"
                        android:text="Ayarla" android:textSize="12sp" android:backgroundTint="#2E7D32"
                        android:paddingStart="12dp" android:paddingEnd="12dp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE" android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Spektrum Isik" android:textSize="13sp" android:textColor="#333" />
                        <TextView android:id="@+id/txt_light_timer" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="06:00 - 22:00 (16 saat)" android:textSize="12sp" android:textColor="#F57F17" android:textStyle="bold" />
                    </LinearLayout>
                    <Button android:id="@+id/btn_light_timer" android:layout_width="wrap_content" android:layout_height="40dp"
                        android:text="Ayarla" android:textSize="12sp" android:backgroundTint="#F57F17"
                        android:paddingStart="12dp" android:paddingEnd="12dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- KART 8: Sistem Sifirla -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" app:cardCornerRadius="12dp" app:cardElevation="3dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Sistem Kontrolu" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="#C62828" android:layout_marginBottom="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ESP32 yeniden baslatilir ve tum pompalar durur"
                    android:textSize="11sp" android:textColor="#999" android:layout_marginBottom="12dp" />
                <Button android:id="@+id/btn_reset" android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="Sistemi Sifirla" android:textSize="14sp" android:backgroundTint="#D32F2F" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>